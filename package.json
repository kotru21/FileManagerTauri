{
  "name": "file-manager-tauri",
  "private": false,
  "version": "0.8.5",
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:core": "vitest run --coverage --config vitest.core.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=github",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "biome lint .",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "format": "biome format . --write",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "lint:all": "npm run check && npm run lint:rust",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "verify": "npm run lint:all && npm run typecheck && npm run test:coverage && npm run test:coverage:core",
    "check:imports": "npx madge --circular src",
    "sync:versions": "node scripts/sync-versions.mjs",
    "preversion": "npm run sync:versions",
    "pretauri:build": "npm run sync:versions"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.22",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "axe-core": "^4.11.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.2",
    "madge": "^8.0.0",
    "tailwindcss": "^4.2.1",
    "tsc-files": "^1.1.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vitest-axe": "^0.1.0"
  }
}
